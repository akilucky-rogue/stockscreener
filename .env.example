# ============================================================
# QSDE — Quantitative Stock Decision Engine
# Environment Configuration
# ============================================================
# Copy to .env: copy .env.example .env
# NEVER commit .env — it's in .gitignore.

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://qsde:qsde_dev_2026@localhost:5432/qsde
DATABASE_URL_ASYNC=postgresql+asyncpg://qsde:qsde_dev_2026@localhost:5432/qsde

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── API Keys (Tier 1) ────────────────────────────────────────
FMP_API_KEY=your_fmp_key_here
FINNHUB_API_KEY=your_finnhub_key_here
FRED_API_KEY=your_fred_key_here

# ── Choice Equity Broker API ─────────────────────────────────
CHOICE_CLIENT_ID=your_choice_ucc
CHOICE_API_KEY=

# ── Zerodha Kite Connect ─────────────────────────────────────
# Sign up at https://developers.kite.trade. ₹500 setup + ₹2000/month.
# api_secret is SECRET -- regenerate immediately if it leaks.
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=http://127.0.0.1:8000/api/kite/callback
# Switch between "kite" (live) and "yfinance" (fallback)
MARKET_DATA_SOURCE=yfinance

# ── Telegram Notifications ───────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=

# ── Application Settings ─────────────────────────────────────
APP_ENV=local
LOG_LEVEL=INFO
TIMEZONE=Asia/Kolkata
